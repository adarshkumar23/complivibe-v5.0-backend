APP_NAME=CompliVibe Backend
APP_ENV=development
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://complivibe_user:change_me@localhost:5432/complivibe
SECRET_KEY=replace_with_secure_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
ACTIVATION_TOKEN_EXPIRE_HOURS=72
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Vault/OpenBao (see docs/runbooks/secrets_management.md)
VAULT_ADDR=
VAULT_TOKEN=
VAULT_TRANSIT_KEY_NAME=complivibe-secrets

# AI provider chain (Groq primary -> Azure OpenAI fallback)
# GROQ_MODEL is env-configurable so a Groq deprecation is a config change, not a
# code change. Default is Groq's current production-tier reasoning flagship.
# Do NOT use preview-only models (e.g. qwen3.6-27b).
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
GROQ_MAX_TOKENS=8192
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=

# Error monitoring -- unwired until a real DSN is supplied
SENTRY_DSN=

# Razorpay billing -- unwired until real, freshly-rotated live keys are supplied
# (the previous key ID was exposed in DEVELOPMENT_LOG_V5.md git history and must
# be rotated in the Razorpay console before use, not reused)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# AWS SES (transactional email) -- unwired until real, freshly-rotated keys are
# supplied (same git-history exposure caveat as Razorpay above)
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
AWS_SES_REGION=ap-south-1
AWS_SES_FROM_EMAIL=
